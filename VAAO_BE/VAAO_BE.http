@VAAO_BE_HostAddress = http://localhost:5048

GET {{VAAO_BE_HostAddress}}/weatherforecast/
Accept: application/json

###

POST {{VAAO_BE_HostAddress}}/api/AzureOpenAi/Chat
Content-Type: application/json

{
  "prompt": "Dame un resumen corto de mi negocio.",
  "systemPrompt": "Responde en espanol de forma clara y breve.",
  "temperature": 0.7,
  "maxTokens": 250
}

###

POST {{VAAO_BE_HostAddress}}/api/AzureOpenAi/ResumenVentas
Content-Type: application/json

{
  "fechaInicio": "2026-04-01",
  "fechaFin": "2026-04-02",
  "cliente": "Oxxo",
  "pregunta": "Dame un resumen de las ventas del rango para este cliente e indica oportunidades o hallazgos."
}

###

POST {{VAAO_BE_HostAddress}}/api/AiAssistant/ChatVentas
Content-Type: application/json

{
  "conversationId": "ventas-chat-1",
  "message": "Dame un resumen de ventas de Oxxo esta semana y dime si va mejor o peor.",
  "modulo": "ventas"
}

###

POST {{VAAO_BE_HostAddress}}/api/AiAssistant/ChatVentas
Content-Type: application/json

{
  "conversationId": "ventas-chat-1",
  "message": "Y cual fue el mejor cliente del mes pasado?",
  "modulo": "ventas"
}

